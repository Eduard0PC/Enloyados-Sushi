{
  "version": 2,
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.7.4"
    }
  ],
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*\\.(css|js|jpg|jpeg|png|gif|svg|ico|webp|woff|woff2|ttf|eot))$",
      "headers": {
        "cache-control": "public, max-age=31536000, immutable"
      }
    },
    {
      "src": "/menu\\.php$",
      "dest": "/menu.php"
    },
    {
      "src": "/about\\.php$",
      "dest": "/about.php"
    },
    {
      "src": "/contact\\.php$",
      "dest": "/contact.php"
    },
    {
      "src": "/login\\.php$",
      "dest": "/login.php"
    },
    {
      "src": "/dashboard\\.php$",
      "dest": "/dashboard.php"
    },
    {
      "src": "/users\\.php$",
      "dest": "/users.php"
    },
    {
      "src": "/verusers\\.php$",
      "dest": "/verusers.php"
    },
    {
      "src": "/vermenu\\.php$",
      "dest": "/vermenu.php"
    },
    {
      "src": "/addmenu\\.php$",
      "dest": "/addmenu.php"
    },
    {
      "src": "/(.*\\.php)$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}